SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/removebgdb?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

LOGGING_LEVEL_ORG_HIBERNATE_SQL=INFO
LOGGING_LEVEL_ORG_HIBERNATE_ORM_JDBC_BIND=INFO

CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ALLOWED_CLOCK_SKEW_SECONDS=60

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5174/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5174/payment/cancel
STRIPE_PRICE_ID_BASIC=price_your_basic_package_price_id
STRIPE_PRICE_ID_PREMIUM=price_your_premium_package_price_id
STRIPE_PRICE_ID_ULTIMATE=price_your_ultimate_package_price_id

REMOVEBG_API_KEY=your_removebg_api_key
REMOVEBG_BASE_URL=https://api.remove.bg/v1.0

APP_CORS_ALLOWED_ORIGINS=http://localhost:5174

SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=2GB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=2GB
